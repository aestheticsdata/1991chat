# ─── HTTP ────────────────────────────────────────────────────────────────────
# API port (the Next.js front dev server uses 6401).
PORT=6400
# Allowed browser origin (the Next.js front). The BFF calls us server-to-server,
# but this keeps direct browser calls during dev working. In prod set this to the
# front's real origin (your domain behind nginx).
CORS_ORIGIN=http://localhost:6401

# ─── LLM provider ────────────────────────────────────────────────────────────
# 'mock' (default) streams random English text. 'remote' uses the vendor-neutral
# HTTP adapter (you implement the provider mapping).
LLM_PROVIDER=mock
# Required even in mock mode, so the auth wiring mirrors a real provider.
# The app refuses to start if this is empty.
LLM_API_KEY=fake-local-key
# Only used when LLM_PROVIDER=remote.
LLM_BASE_URL=

# ─── Mock behaviour (scenarios triggered by a keyword in the chat message) ────
# Drop "/error", "/slow" or "/pending" anywhere in a message to exercise that
# scenario; no keyword streams a normal reply. The knobs below tune each one.
MOCK_TOKEN_DELAY_MS=45
MOCK_SLOW_TOKEN_DELAY_MS=600
MOCK_PENDING_DELAY_MS=8000
# Sentence corpus the mock streams from (path relative to the backend cwd). Holds
# clean standalone sentences; the mock streams a handful at random per reply.
# Optional local artifact: if the file is missing, the mock falls back to a
# small built-in sentence pool.
MOCK_CORPUS_PATH=./assets/mock-corpus.txt

# ─── Persistence (SQLite file on disk) ───────────────────────────────────────
DATABASE_PATH=./data/1991chat.db

# ─── Sessions (Redis-backed, httpOnly cookie) ────────────────────────────────
REDIS_URL=redis://localhost:6379
# Required. Signs the session id cookie. Change in any real deployment.
SESSION_SECRET=dev-session-secret-change-me
SESSION_COOKIE_NAME=1991chat.sid
# Idle timeout in seconds: the session dies after this long with NO activity.
# rolling:true + connect-redis touch slide it back to the full value on every
# authenticated request, so it's a sliding window. 1200 = 20 minutes.
SESSION_TTL_SECONDS=1200
SESSION_REDIS_PREFIX=1991chat:sess:
# Set true in production (HTTPS). The BFF forwards X-Forwarded-Proto so the
# session cookie is only emitted over secure connections there.
COOKIE_SECURE=false

# ─── Auth ────────────────────────────────────────────────────────────────────
# Optional: seed a default user on startup (leave blank to seed nothing — create
# accounts via the signup page / POST /auth/register instead).
AUTH_DEFAULT_USERNAME=
AUTH_DEFAULT_PASSWORD=
